APP_NAME=GPMS API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
# If PostgreSQL runs via Docker on the same machine:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gpms
# Optional fallback for local demo without PostgreSQL:
# DATABASE_URL=sqlite:///./gpms.db
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_THIS_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080
SEED_ALLOW_UNAUTHENTICATED=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Docker database settings (used by docker-compose.yml)
POSTGRES_DB=gpms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=admin@gpms.local
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050
